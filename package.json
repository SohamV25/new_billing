{
  "name": "new_billing_monorepo",
  "version": "1.0.0",
  "description": "Monorepo for Billing Application",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install && npm install --workspace=client && npm install --workspace=server",
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run start --workspace=server\"",
    "build:client": "npm run build --workspace=client",
    "start:server": "npm run start --workspace=server",
    "seed:server": "npm run seed --workspace=server",
    "start": "npm run start:server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
